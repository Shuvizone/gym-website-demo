*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
 background:#111;
 color:white;
 font-family:Poppins,sans-serif;
}

h1{
 text-align:center;
}

nav{
display:flex;
justify-content:space-between;
padding:20px;
background:black;
color:white;
}

ul{
display:flex;
gap:20px;
list-style:none;
}

a{
text-decoration:none;
color:white;
}

header{
height:80vh;
display:flex;
justify-content:center;
align-items:center;
background:#111;
color:white;
text-align:center;
}

.hero h1{
font-size:60px;
margin-bottom:20px;
}

.btn{
background:#ff6b00;
padding:15px 25px;
display:inline-block;
margin-top:20px;
border-radius:5px;
}

section{
padding:60px 10%;
}

.cards{
display:grid;
grid-template-columns:
repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:30px;
}

.card{
background:white;
padding:30px;
text-align:center;
border-radius:10px;
}

.pricing{
display:grid;
grid-template-columns:
repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.plan{
background:white;
padding:30px;
text-align:center;
border-radius:10px;
}

input,
textarea{
width:100%;
padding:15px;
margin:10px 0;
}

button{
background:#ff6b00;
color:white;
padding:15px;
border:none;
cursor:pointer;
}

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:green;
padding:15px;
border-radius:50px;
}
.hero{
 background:
 url("images/couple cycling.jpg");
}